{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Customer service request for consignment or chauffeur",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "type": { "type": "string", "enum": ["consignment", "chauffeur"], "description": "Service type" },
        "customerPhone": { "type": "string", "description": "Customer phone number" },
        "carName": { "type": "string", "description": "Car name" },
        "transmission": { "type": "string", "description": "Transmission type (Auto/Manual)" },
        "operationStatus": { "type": "string", "description": "Operation status (for consignment)" },
        "departureAddr": { "type": "string", "description": "Departure address" },
        "departureContact": { "type": "string", "description": "Departure contact" },
        "arrivalAddr": { "type": "string", "description": "Arrival address" },
        "arrivalContact": { "type": "string", "description": "Arrival contact" },
        "hasStopover": { "type": "boolean", "description": "Whether there is a stopover" },
        "stopoverAddr": { "type": "string", "description": "Stopover address" },
        "stopoverContact": { "type": "string", "description": "Stopover contact" },
        "distance": { "type": "number", "description": "Estimated distance in km" },
        "estimatedFare": { "type": "number", "description": "Calculated fare" },
        "paymentMethod": { "type": "string", "enum": ["prepaid", "postpaid"], "description": "Payment method" },
        "status": { "type": "string", "enum": ["pending", "assigned", "completed"], "description": "Order status" },
        "memo": { "type": "string", "description": "Additional memo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order creation time" }
      },
      "required": ["type", "customerPhone", "departureAddr", "arrivalAddr", "status"]
    },
    "Content": {
      "title": "Content",
      "description": "Editable website content",
      "type": "object",
      "properties": {
        "key": { "type": "string", "description": "Unique key for the content piece" },
        "value": { "type": "string", "description": "The actual text content" },
        "type": { "type": "string", "enum": ["text", "image"], "description": "Type of content" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["key", "value", "type"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "points": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "PointLog": {
      "title": "PointLog",
      "description": "History of point transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "balanceAfter", "createdAt"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer service requests"
    },
    "/contents/{contentId}": {
      "schema": "Content",
      "description": "Editable website content"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/point_logs/{logId}": {
      "schema": "PointLog",
      "description": "Point transaction logs"
    }
  }
}
